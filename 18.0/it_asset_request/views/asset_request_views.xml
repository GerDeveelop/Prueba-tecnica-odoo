<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_it_asset_request_list" model="ir.ui.view">
        <field name="name">it.asset.request.list</field>
        <field name="model">it.asset.request</field>
        <field name="arch" type="xml">
            <list string="Solicitudes de Activos">
                <field name="name" readonly="1"/>
                <field name="employee_id"/>
                <field name="asset_type"/>
                <field name="priority" widget="badge" 
                       decoration-danger="priority == 'alta'" 
                       decoration-warning="priority == 'media'" 
                       decoration-info="priority == 'baja'"/>
                <field name="state" widget="badge" 
                       decoration-success="state == 'approved'" 
                       decoration-info="state == 'submitted'" 
                       decoration-muted="state == 'draft'" 
                       decoration-danger="state == 'rejected'"/>
            </list>
        </field>
    </record>

    <record id="view_it_asset_request_form" model="ir.ui.view">
        <field name="name">it.asset.request.form</field>
        <field name="model">it.asset.request</field>
        <field name="arch" type="xml">
            <form string="Detalle de Solicitud">
                <header>
                    <button name="action_submit" string="Enviar a Revisión" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_approve" string="Aprobar" type="object" class="oe_highlight" invisible="state != 'submitted'"/>
                    <button name="action_reject" string="Rechazar" type="object" invisible="state != 'submitted'"/>
                    
                    <button name="%(action_report_it_asset_request)d" string="Imprimir PDF" type="action" icon="fa-print"/>
                    
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,approved,rejected"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" string="Número de Solicitud"/>
                        <h1><field name="name" readonly="1"/></h1>
                        <h2 class="text-muted"><field name="display_name_info" readonly="1" force_save="1"/></h2>
                    </div>
                    <group>
                        <group name="solicitante" string="Información General">
                            <field name="employee_id" readonly="state != 'draft'" options="{'no_create': True}"/>
                            <field name="employee_email"/>
                            <field name="asset_type" readonly="state != 'draft'"/>
                            <field name="attachment" filename="attachment_name" readonly="state != 'draft'"/>
                            <field name="attachment_name" invisible="1"/>
                        </group>
                        <group name="logistica" string="Prioridad y Costos">
                            <field name="request_date"/>
                            <field name="priority" readonly="state != 'draft'"/>
                            <field name="is_urgent" readonly="1" force_save="1"/>
                            <field name="estimated_cost" readonly="state != 'draft'"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notas de Justificación" name="justification">
                            <field name="justification" placeholder="Describa el motivo de la solicitud..." readonly="state != 'draft'"/>
                        </page>
                        <page string="Auditoría de Aprobación" name="approval" invisible="state not in ('approved', 'rejected')">
                            <group>
                                <field name="approved_by"/>
                                <field name="approval_date"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_it_asset_request_search" model="ir.ui.view">
        <field name="name">it.asset.request.search</field>
        <field name="model">it.asset.request</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="employee_id"/>
                <filter string="Pendientes de Aprobación" name="pending" domain="[('state', '=', 'submitted')]"/>
                <group expand="0" string="Agrupar Por">
                    <filter string="Estado" name="state" context="{'group_by': 'state'}"/>
                    <filter string="Tipo de Activo" name="asset" context="{'group_by': 'asset_type'}"/>
                </group>
            </search>
        </field>
    </record>
</odoo>